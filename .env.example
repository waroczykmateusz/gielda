# Wymagane zmienne środowiskowe (skopiuj do .env i uzupełnij wartościami).
# Na produkcji ustawiane w Vercel Project Settings → Environment Variables.

# Auto-injected przez integrację Vercel Postgres
POSTGRES_URL=

# Telegram bot — skopiuj z dawnego config.py
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Anthropic Claude API — skopiuj z dawnego config.py
ANTHROPIC_API_KEY=

# Sekret weryfikujący nagłówek Authorization w cron handlerach (Vercel auto-generuje)
CRON_SECRET=
