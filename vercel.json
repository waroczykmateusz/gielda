{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/portfolio/:tab", "destination": "/api/index" },
    { "source": "/api/transaction", "destination": "/api/index" },
    { "source": "/api/alert", "destination": "/api/index" },
    { "source": "/api/health", "destination": "/api/index" },
    { "source": "/api/dividends", "destination": "/api/dividends" },
    { "source": "/api/chart", "destination": "/api/chart" },
    { "source": "/api/correlation", "destination": "/api/correlation" },
    { "source": "/api/recommendation", "destination": "/api/recommendation" },
    { "source": "/api/recommend", "destination": "/api/recommend" },
    { "source": "/api/cron/morning", "destination": "/api/cron/morning" },
    { "source": "/api/cron/alerts", "destination": "/api/cron/alerts" },
    { "source": "/api/cron/gpw_report", "destination": "/api/cron/gpw_report" },
    { "source": "/api/cron/usa_report", "destination": "/api/cron/usa_report" }
  ],
  "crons": []
}
